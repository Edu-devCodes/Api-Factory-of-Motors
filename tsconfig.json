{
  "compilerOptions": {
   
    "target": "es2023",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    
    "types": ["node"],
    "lib": ["ES2022"],

   
    "strict": true,
    "skipLibCheck": true,

   
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

  
    "rootDir": ".",
    "outDir": "build",
    "sourceMap": true,

  
    "resolveJsonModule": true
  },

  "include": [
    "src",
    "prisma",
    "*.ts"
  ],

  "exclude": [
    "node_modules",
    "build"
  ]
}